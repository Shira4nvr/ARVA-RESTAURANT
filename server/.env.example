# 🔐 Configuración de Variables de Entorno
# Copia este archivo a .env y rellena los valores

# ✅ DESARROLLO LOCAL CON MONGODB
# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/arva-restaurant
# JWT_SECRET=ARVA_SECRET_2024_SUPER_SECRETO

# ✅ MONGODB ATLAS (Recomendado para Producción)
PORT=5000
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/arva-restaurant?retryWrites=true&w=majority
JWT_SECRET=ARVA_SECRET_2024_SUPER_SECRETO

# 📝 Reemplaza:
# - <usuario>: Tu usuario de MongoDB Atlas (ej: arva_admin)
# - <contraseña>: Tu contraseña (usa %40 para @, %3A para :, etc)
# - <cluster>: Tu cluster (ej: cluster0)

# 🌐 Ejemplo Real de MongoDB Atlas:
# MONGODB_URI=mongodb+srv://arva_admin:MyPass123@cluster0.mongodb.net/arva-restaurant?retryWrites=true&w=majority

# 🔗 Obtén tu URI en MongoDB Atlas:
# 1. Ve a Clusters
# 2. Haz clic en "Connect"
# 3. Selecciona "Connect your application"
# 4. Elige Node.js
# 5. Copia la URI completa
